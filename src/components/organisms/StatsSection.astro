---
import Img from "@/components/atoms/Img.astro";
import { Counter } from "@/components/islands/Counter";
import Reveal from "@/components/transitions/Reveal.astro";
import { stats } from "@/lib/data/stats";

interface Props {
  backgroundImage?: string;
  class?: string;
}

const {
  backgroundImage = "/images/banner/banner_horizontal_splash_1.png",
  class: className,
} = Astro.props;
---

<section
  class:list={["stats-dark relative overflow-hidden", className]}
  aria-label="Estadísticas"
>
  <!-- Parallax background -->
  <div class="absolute inset-0 overflow-hidden" aria-hidden="true">
    <Img
      src={backgroundImage}
      alt=""
      width={1440}
      height={600}
      class="absolute w-full object-cover will-change-transform"
      style="top:-40%;height:180%"
      data-parallax-img
      data-parallax-speed="0.4"
    />
    <div class="absolute inset-0 bg-black/72"></div>
    <div
      class="absolute inset-0 bg-linear-to-r from-brand-red/20 to-transparent"
    >
    </div>
  </div>

  <div class="container-content section-padding relative z-10 py-20 xl:py-28">
    <Reveal class="mb-12 text-center">
      <span
        class="mb-3 inline-block text-xs font-semibold uppercase tracking-[0.2em] text-brand-red"
      >
        En números
      </span>
      <h2 class="font-display text-3xl font-bold text-white xl:text-4xl">
        33 años de trayectoria nos respaldan
      </h2>
    </Reveal>

    <div class="grid grid-cols-2 gap-8 xl:grid-cols-4 xl:gap-12">
      {
        stats.map((stat, i) => (
          <Reveal delay={((i % 4) + 1) as 1 | 2 | 3 | 4}>
            <Counter
              client:visible
              target={stat.value}
              suffix={stat.suffix ?? ""}
              label={stat.label}
            />
          </Reveal>
        ))
      }
    </div>
  </div>
</section>

<style>
  /* Override color tokens locally so Counter's inline style vars read white */
  .stats-dark {
    --color-text-primary: #ffffff;
    --color-text-muted: rgba(255, 255, 255, 0.6);
  }
</style>
