---
import Logo from '@/components/atoms/Logo.astro'
import SocialLink from '@/components/molecules/SocialLink.astro'
import Divider from '@/components/atoms/Divider.astro'
import { navItems } from '@/lib/data/nav'
import { contactInfo } from '@/lib/data/contact'

const currentYear = new Date().getFullYear()

const services = [
  { label: 'Impresión Offset',    href: '/portafolio?cat=offset' },
  { label: 'Impresión Digital',   href: '/portafolio?cat=digital' },
  { label: 'Gran Formato',        href: '/portafolio?cat=gran-formato' },
  { label: 'Material POP',        href: '/portafolio?cat=pop' },
  { label: 'Empaques',            href: '/portafolio?cat=empaques' },
]
---

<footer class="bg-surface-base border-t border-surface-border">
  <div class="container-content section-padding py-16 xl:py-20">
    <div class="grid grid-cols-1 gap-12 xl:grid-cols-4">

      <!-- Col 1: Brand -->
      <div class="xl:col-span-1">
        <Logo size="md" class="mb-4" />
        <p class="text-sm text-text-muted leading-relaxed max-w-xs">
          Empresa especializada en artes gráficas e impresión con más de 33 años de experiencia
          en Bogotá, Colombia.
        </p>
        {contactInfo.social && (
          <div class="mt-6 flex items-center gap-4">
            {contactInfo.social.instagram && (
              <SocialLink platform="instagram" href={contactInfo.social.instagram} />
            )}
            {contactInfo.social.linkedin && (
              <SocialLink platform="linkedin" href={contactInfo.social.linkedin} />
            )}
            {contactInfo.social.behance && (
              <SocialLink platform="behance" href={contactInfo.social.behance} />
            )}
          </div>
        )}
      </div>

      <!-- Col 2: Navigation -->
      <div>
        <h3 class="text-xs font-semibold uppercase tracking-widest text-text-muted mb-5">
          Navegación
        </h3>
        <ul class="space-y-3">
          {navItems.map((item) => (
            <li>
              <a
                href={item.href}
                class="text-sm text-text-secondary hover:text-brand-red transition-colors duration-200"
              >
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Col 3: Services -->
      <div>
        <h3 class="text-xs font-semibold uppercase tracking-widest text-text-muted mb-5">
          Servicios
        </h3>
        <ul class="space-y-3">
          {services.map((s) => (
            <li>
              <a
                href={s.href}
                class="text-sm text-text-secondary hover:text-brand-red transition-colors duration-200"
              >
                {s.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Col 4: Contact -->
      <div>
        <h3 class="text-xs font-semibold uppercase tracking-widest text-text-muted mb-5">
          Contacto
        </h3>
        <ul class="space-y-3 text-sm text-text-secondary">
          <li>
            <a
              href={`mailto:${contactInfo.email}`}
              class="hover:text-brand-red transition-colors duration-200"
            >
              {contactInfo.email}
            </a>
          </li>
          <li>
            <a
              href={`tel:${contactInfo.phone.replace(/\s/g, '')}`}
              class="hover:text-brand-red transition-colors duration-200"
            >
              {contactInfo.phone}
            </a>
          </li>
          <li class="text-text-muted">{contactInfo.address}</li>
          <li class="text-text-muted">{contactInfo.schedule}</li>
        </ul>
      </div>
    </div>

    <Divider class="mt-14" />

    <!-- Bottom bar -->
    <div class="mt-6 flex flex-col items-center gap-3 xl:flex-row xl:justify-between">
      <p class="text-xs text-text-muted">
        © {currentYear} GrafiVisión. Todos los derechos reservados.
      </p>
      <p class="text-xs text-text-muted">
        Hecho con ❤ en Colombia
      </p>
    </div>
  </div>
</footer>
