---
import Button from '@/components/atoms/Button.astro'
import Logo from '@/components/atoms/Logo.astro'
import { MobileMenu } from '@/components/islands/MobileMenu'
import NavItem from '@/components/molecules/NavItem.astro'
import { navItems } from '@/lib/data/nav'
---

<header
  id="site-header"
  class="sticky top-0 z-[9999] w-full border-b border-surface-border bg-surface-raised/90 backdrop-blur-md transition-shadow duration-300"
>
  <div class="container-content section-padding">
    <div class="flex h-16 items-center justify-between xl:h-20">

      <!-- Logo -->
      <Logo size="md" />

      <!-- Desktop nav -->
      <nav class="hidden xl:flex items-center gap-8" aria-label="Navegación principal">
        <ul class="flex items-center">
          {navItems.map((item, index) => (
            <>
              {index > 0 && (
                <li aria-hidden="true" class="select-none px-3 text-brand-red font-light">/</li>
              )}
              {item.children ? (
                <li class="relative group">
                  <button
                    type="button"
                    class="flex items-center gap-1 text-sm font-medium text-text-secondary hover:text-text-primary transition-colors duration-200 cursor-default"
                    aria-haspopup="true"
                  >
                    {item.label}
                    <svg
                      width={14}
                      height={14}
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                      class="transition-transform duration-200 group-hover:rotate-180"
                      aria-hidden="true"
                    >
                      <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                    </svg>
                  </button>

                  <!-- Dropdown -->
                  <ul
                    class="absolute top-full left-1/2 -translate-x-1/2 mt-3 w-44 rounded-xl border border-surface-border bg-surface-overlay py-1.5 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 shadow-lg"
                    role="menu"
                  >
                    {item.children.map((child) => (
                      <li role="none">
                        <a
                          href={child.href}
                          role="menuitem"
                          aria-label={child.label}
                          class="block px-4 py-2 text-sm text-text-secondary hover:text-brand-red hover:bg-surface-muted transition-colors duration-150"
                        >
                          {child.label}
                        </a>
                      </li>
                    ))}
                  </ul>
                </li>
              ) : (
                <li>
                  <NavItem label={item.label} href={item.href} />
                </li>
              )}
            </>
          ))}
        </ul>

        <Button href="/contacto" variant="primary" size="sm">
          Contáctanos
        </Button>
      </nav>

      <!-- Mobile menu trigger + drawer (React island) -->
      <MobileMenu client:load navItems={navItems} />
    </div>
  </div>
</header>

<script is:inline>
  ;(function () {
    var header = document.getElementById('site-header')
    if (!header) return
    function update() {
      if (window.scrollY > 8) {
        header.classList.add('shadow-md')
        header.classList.remove('shadow-none')
      } else {
        header.classList.remove('shadow-md')
        header.classList.add('shadow-none')
      }
    }
    window.addEventListener('scroll', update, { passive: true })
    update()
  })()
</script>
