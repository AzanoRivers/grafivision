---
import Button from "@/components/atoms/Button.astro";
import Reveal from "@/components/transitions/Reveal.astro";

interface Props {
  title?: string;
  subtitle?: string;
  primaryLabel?: string;
  primaryHref?: string;
  secondaryLabel?: string;
  secondaryHref?: string;
  class?: string;
}

const {
  title = "¿Listo para transformar tu marca?",
  subtitle = "Cuéntanos tu proyecto. En 24 horas te respondemos con una propuesta inicial.",
  primaryLabel = "Iniciar proyecto",
  primaryHref = "/contacto",
  secondaryLabel = "Ver portafolio",
  secondaryHref = "/portafolio",
  class: className,
} = Astro.props;
---

<section class:list={["relative overflow-hidden bg-surface-raised", className]}>
  <!-- Red decorative blobs -->
  <div
    class="pointer-events-none absolute -left-32 -top-32 h-96 w-96 rounded-full bg-brand-red/10 blur-3xl"
    aria-hidden="true"
  >
  </div>
  <div
    class="pointer-events-none absolute -bottom-24 -right-24 h-72 w-72 rounded-full bg-brand-red/8 blur-2xl"
    aria-hidden="true"
  >
  </div>

  <!-- Diagonal accent line top -->
  <div
    class="absolute left-0 top-0 h-1 w-full bg-linear-to-r from-brand-red via-brand-orange/40 to-transparent"
    aria-hidden="true"
  >
  </div>

  <div class="container-content section-padding py-20 xl:py-28">
    <div
      class="grid grid-cols-1 gap-10 xl:grid-cols-2 xl:items-center xl:gap-20"
    >
      <!-- Text -->
      <Reveal>
        <span
          class="mb-4 inline-block text-xs font-semibold uppercase tracking-[0.2em] text-brand-red"
        >
          Trabajemos juntos
        </span>
        <h2
          class="font-display text-3xl font-bold leading-tight text-text-primary xl:text-5xl"
        >
          {title}
        </h2>
        <p class="mt-5 max-w-lg text-text-secondary leading-relaxed">
          {subtitle}
        </p>
      </Reveal>

      <!-- Actions -->
      <Reveal delay={1} class="flex flex-col gap-4 lg:flex-row xl:justify-end">
        <Button href={primaryHref} variant="primary" size="lg">
          {primaryLabel}
          <svg
            width={16}
            height={16}
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            aria-hidden="true"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"></path>
          </svg>
        </Button>
        <Button href={secondaryHref} variant="outline" size="lg">
          {secondaryLabel}
        </Button>
      </Reveal>
    </div>
  </div>
</section>
