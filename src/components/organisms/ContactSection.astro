---
import { ContactForm } from "@/components/islands/ContactForm";
import ContactInfoItem from "@/components/molecules/ContactInfoItem.astro";
import SocialLink from "@/components/molecules/SocialLink.astro";
import MapEmbed from "@/components/organisms/MapEmbed.astro";
import Reveal from "@/components/transitions/Reveal.astro";
import { contactInfo } from "@/lib/data/contact";

interface Props {
  class?: string;
}

const { class: className } = Astro.props;
---

<section class:list={["bg-surface-base", className]} id="contacto">
  <div class="container-content section-padding section-gap">
    <!-- Header -->
    <Reveal class="mb-12 text-center">
      <span
        class="mb-3 inline-block text-xs font-semibold uppercase tracking-[0.2em] text-brand-red"
      >
        Contacto
      </span>
      <h2 class="font-display text-3xl font-bold text-text-primary xl:text-5xl">
        Hablemos de tu proyecto
      </h2>
      <p class="mt-4 text-text-secondary max-w-xl mx-auto">
        Cuéntanos tu idea. Estamos listos para crear algo memorable juntos.
      </p>
    </Reveal>

    <div class="grid grid-cols-1 gap-12 xl:grid-cols-2 xl:gap-16">
      <!-- Left: info + map -->
      <Reveal class="flex flex-col gap-8">
        <div class="flex flex-col gap-6">
          <ContactInfoItem
            icon="mail"
            label="Email"
            value={contactInfo.email}
            href={`mailto:${contactInfo.email}`}
          />
          <ContactInfoItem
            icon="phone"
            label="Teléfono fijo"
            value={contactInfo.phone}
            href={`tel:${contactInfo.phone.replace(/\s/g, "")}`}
          />
          {
            contactInfo.mobile && (
              <ContactInfoItem
                icon="smartphone"
                label="Móvil"
                value={contactInfo.mobile}
                href={`tel:${contactInfo.mobile.replace(/\s/g, "")}`}
              />
            )
          }
          <ContactInfoItem
            icon="map-pin"
            label="Ubicación"
            value={contactInfo.address}
          />
          <ContactInfoItem
            icon="clock"
            label="Horario"
            value={contactInfo.schedule}
          />
        </div>

        <!-- Social -->
        <div>
          <p
            class="mb-3 text-xs font-semibold uppercase tracking-wider text-text-muted"
          >
            Síguenos
          </p>
          <div class="flex gap-4">
            {
              contactInfo.social.instagram && (
                <SocialLink
                  platform="instagram"
                  href={contactInfo.social.instagram}
                  label
                />
              )
            }
            {
              contactInfo.social.linkedin && (
                <SocialLink
                  platform="linkedin"
                  href={contactInfo.social.linkedin}
                  label
                />
              )
            }
            {
              contactInfo.social.behance && (
                <SocialLink
                  platform="behance"
                  href={contactInfo.social.behance}
                  label
                />
              )
            }
          </div>
        </div>

        <!-- Map -->
        <MapEmbed height="240px" />
      </Reveal>

      <!-- Right: form -->
      <Reveal delay={1}>
        <div
          class="rounded-2xl border border-surface-border bg-surface-raised p-6 xl:p-8"
        >
          <h3 class="font-display text-xl font-bold text-text-primary mb-6">
            Envíanos un mensaje
          </h3>
          <ContactForm client:visible />
        </div>
      </Reveal>
    </div>
  </div>
</section>
