---
import Divider from '@/components/atoms/Divider.astro'
import Reveal from '@/components/transitions/Reveal.astro'

interface ValueItem {
  icon: string
  title: string
  description: string
}

interface Props {
  class?: string
}

const { class: className } = Astro.props

const values: ValueItem[] = [
  {
    icon: 'experiencia',
    title: 'Experiencia',
    description: 'Más de 33 años de trayectoria en el sector gráfico.',
  },
  {
    icon: 'calidad',
    title: 'Calidad',
    description: 'Procesos controlados que garantizan resultados consistentes.',
  },
  {
    icon: 'tecnologia',
    title: 'Tecnología',
    description: 'Equipos de impresión de última generación.',
  },
  {
    icon: 'sostenibilidad',
    title: 'Sostenibilidad',
    description: 'Procesos responsables con el medio ambiente.',
  },
]

// Inline SVG paths per value (no icon library dependency)
const iconPaths: Record<string, string> = {
  experiencia: 'M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z',
  calidad: 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z',
  tecnologia: 'M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z',
  sostenibilidad: 'M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z',
}
---

<section class:list={['bg-surface-raised', className]}>
  <div class="container-content section-padding section-gap">

    <!-- Header -->
    <Reveal class="text-center">
      <span class="mb-4 inline-block text-xs font-semibold uppercase tracking-[0.2em] text-brand-red">
        Nuestros diferenciales
      </span>
      <h2 class="font-display text-3xl font-bold text-text-primary xl:text-4xl">
        Lo que nos diferencia
      </h2>
      <Divider variant="accent" class="mx-auto my-6 w-12" />
      <p class="mx-auto max-w-xl text-text-secondary leading-relaxed">
        Los pilares que guían cada proyecto y cada entrega en GrafiVisión.
      </p>
    </Reveal>

    <!-- Values grid -->
    <div class="mt-12 grid grid-cols-1 gap-6 lg:grid-cols-2 2xl:grid-cols-4">
      {values.map((v, i) => (
        <Reveal delay={Math.min(i, 3) as 0|1|2|3}>
          <article class="group flex flex-col gap-5 rounded-2xl border border-surface-border bg-surface-overlay p-6 transition-colors duration-300 hover:border-brand-red/40">

            <!-- Icon -->
            <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-brand-red/10 transition-colors duration-300 group-hover:bg-brand-red">
              <svg
                width="22"
                height="22"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.5"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="text-brand-red transition-colors duration-300 group-hover:text-white"
                aria-hidden="true"
              >
                <path d={iconPaths[v.icon]} />
              </svg>
            </div>

            <!-- Text -->
            <div>
              <h3 class="font-display text-base font-bold text-text-primary">{v.title}</h3>
              <p class="mt-2 text-sm text-text-secondary leading-relaxed">{v.description}</p>
            </div>

          </article>
        </Reveal>
      ))}
    </div>

  </div>
</section>
