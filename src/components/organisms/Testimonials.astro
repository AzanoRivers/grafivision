---
import Avatar from '@/components/atoms/Avatar.astro'
import Blockquote from '@/components/atoms/Blockquote.astro'
import Reveal from '@/components/transitions/Reveal.astro'
import { testimonials } from '@/lib/data/testimonials'

interface Props {
  class?: string
}

const { class: className } = Astro.props
---

<section class:list={['bg-surface-base', className]}>
  <div class="container-content section-padding section-gap">
    <Reveal class="mb-12 text-center">
      <span class="mb-3 inline-block text-xs font-semibold uppercase tracking-[0.2em] text-brand-red">
        Testimonios
      </span>
      <h2 class="font-display text-3xl font-bold text-text-primary xl:text-4xl">
        Lo que dicen nuestros clientes
      </h2>
    </Reveal>

    <div class="grid grid-cols-1 gap-6 lg:grid-cols-2 2xl:grid-cols-4">
      {testimonials.map((t, i) => (
        <Reveal delay={(i % 4 + 1) as 1|2|3|4}>
          <article class="flex flex-col gap-5 rounded-2xl border border-surface-border bg-surface-raised p-6 h-full">
            <!-- Stars -->
            <div class="flex gap-1" aria-label={`${t.rating ?? 5} de 5 estrellas`}>
              {Array.from({ length: t.rating ?? 5 }).map(() => (
                <svg width={14} height={14} viewBox="0 0 24 24" fill="currentColor" class="text-brand-orange" aria-hidden="true">
                  <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />
                </svg>
              ))}
            </div>

            <Blockquote author={t.author} company={t.company} class="flex-1">
              {t.quote}
            </Blockquote>

            <div class="flex items-center gap-3">
              <Avatar alt={t.author} size="sm" />
              <div>
                <p class="text-sm font-semibold text-text-primary">{t.author}</p>
                {t.company && <p class="text-xs text-text-muted">{t.company}</p>}
              </div>
            </div>
          </article>
        </Reveal>
      ))}
    </div>
  </div>
</section>
