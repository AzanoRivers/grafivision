---
import PortfolioCard from '@/components/molecules/PortfolioCard.astro'
import Button from '@/components/atoms/Button.astro'
import Reveal from '@/components/transitions/Reveal.astro'
import { portfolioItems } from '@/lib/data/portfolio'

interface Props {
  title?: string
  subtitle?: string
  limit?: number
  showCta?: boolean
  class?: string
}

const {
  title = 'Portafolio',
  subtitle = 'Una selección de proyectos que reflejan nuestra filosofía creativa.',
  limit = 8,
  showCta = true,
  class: className,
} = Astro.props

const items = portfolioItems.slice(0, limit)
---

<section class:list={['bg-surface-raised', className]}>
  <div class="container-content section-padding section-gap">
    <!-- Header -->
    <Reveal class="mb-12 flex flex-col items-center gap-6 xl:flex-row xl:justify-between">
      <div>
        <span class="mb-2 inline-block text-xs font-semibold uppercase tracking-[0.2em] text-brand-red">
          Portafolio
        </span>
        <h2 class="font-display text-3xl font-bold text-text-primary xl:text-5xl">{title}</h2>
        {subtitle && <p class="mt-3 text-text-secondary max-w-md">{subtitle}</p>}
      </div>
      {showCta && (
        <Button href="/portafolio" variant="outline" size="md" class="shrink-0">
          Ver todo el portafolio
        </Button>
      )}
    </Reveal>

    <!-- Grid -->
    <div class="grid grid-cols-1 gap-5 md:grid-cols-2 xl:grid-cols-4">
      {items.map((item, i) => (
        <Reveal delay={(i % 4 + 1) as 1|2|3|4}>
          <PortfolioCard
            title={item.title}
            category={item.category}
            image={item.thumbnail}
            href={`/portafolio/${item.slug}`}
            class="h-full"
          />
        </Reveal>
      ))}
    </div>
  </div>
</section>
