---
interface Props {
  src?: string
  title?: string
  height?: string
  class?: string
}

const {
  src = import.meta.env.PUBLIC_MAPS_EMBED_URL,
  title = 'Ubicación de GrafiVisión en Google Maps',
  height = '400px',
  class: className,
} = Astro.props
---

{src ? (
  <div class:list={['overflow-hidden rounded-xl border border-surface-border', className]}>
    <iframe
      src={src}
      title={title}
      width="100%"
      height={height}
      loading="lazy"
      referrerpolicy="no-referrer-when-downgrade"
      class="block border-0"
      aria-label={title}
    />
  </div>
) : (
  <div
    class:list={[
      'flex items-center justify-center rounded-xl border border-surface-border bg-surface-raised text-text-muted text-sm',
      className,
    ]}
    style={`height: ${height}`}
  >
    <div class="text-center p-8">
      <svg class="mx-auto mb-3 h-8 w-8 opacity-40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
        <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
      </svg>
      <p>Mapa no configurado</p>
      <p class="text-xs mt-1 opacity-60">Agregar PUBLIC_MAPS_EMBED_URL en .env</p>
    </div>
  </div>
)}
