---
import { SubscribeForm } from '@/components/islands/SubscribeForm'
import Reveal from '@/components/transitions/Reveal.astro'

interface Props {
  title?: string
  subtitle?: string
  class?: string
}

const {
  title = 'Mantente al día con nuestras novedades',
  subtitle = 'Proyectos, tendencias y tips de diseño directo a tu bandeja de entrada.',
  class: className,
} = Astro.props
---

<section class:list={['bg-gradient-to-r from-[#C91920] via-brand-red to-brand-orange', className]} aria-label="Suscripción">
  <div class="container-content section-padding py-14 xl:py-16">
    <div class="grid grid-cols-1 gap-8 xl:grid-cols-2 xl:items-center xl:gap-16">
      <Reveal>
        <h2 class="font-display text-2xl font-bold text-white xl:text-3xl">{title}</h2>
        <p class="mt-2 text-white/70 text-sm">{subtitle}</p>
      </Reveal>
      <Reveal delay={1}>
        <SubscribeForm client:visible />
      </Reveal>
    </div>
  </div>
</section>
