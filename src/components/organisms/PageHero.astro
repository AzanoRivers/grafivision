---
import Badge from '@/components/atoms/Badge.astro'
import Img from '@/components/atoms/Img.astro'
import gf5 from '@/assets/images/brand/GF-5.webp'
import type { ImageMetadata } from 'astro'

interface Props {
  title: string
  subtitle?: string
  badge?: string
  image?: string | ImageMetadata
  class?: string
}

const { title, subtitle, badge, image = gf5, class: className } = Astro.props
---

<section class:list={['relative flex items-center overflow-hidden bg-black py-20 xl:py-28', className]}>
  <!-- Background image with dark overlay + parallax -->
  <div class="absolute inset-0 overflow-hidden" aria-hidden="true">
    <Img
      src={image}
      alt=""
      width={1440}
      height={400}
      class="absolute w-full object-cover opacity-40 will-change-transform"
      style="top:-40%;height:180%"
      loading="eager"
      fetchpriority="high"
      data-parallax-img
      data-parallax-speed="0.45"
    />
    <div class="absolute inset-0 bg-linear-to-r from-black/85 via-black/55 to-transparent" />
  </div>

  <div class="container-content section-padding relative z-10">
    {badge && <Badge variant="red" size="md" class="mb-5">{badge}</Badge>}
    <h1 class="font-display text-4xl font-bold text-white xl:text-6xl max-w-2xl">{title}</h1>
    {subtitle && (
      <p class="mt-5 text-lg text-white/70 max-w-xl">{subtitle}</p>
    )}
  </div>
</section>
