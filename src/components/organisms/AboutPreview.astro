---
import type { ImageMetadata } from 'astro'
import Button from '@/components/atoms/Button.astro'
import Divider from '@/components/atoms/Divider.astro'
import Img from '@/components/atoms/Img.astro'
import Reveal from '@/components/transitions/Reveal.astro'
import gf4 from '@/assets/images/brand/GF-4.webp'

interface Props {
  image?: string | ImageMetadata
  class?: string
}

const {
  image = gf4,
  class: className,
} = Astro.props

const highlights = [
  { value: '12+',  label: 'Años de experiencia' },
  { value: '350+', label: 'Proyectos completados' },
  { value: '120+', label: 'Clientes satisfechos' },
  { value: '4',    label: 'Disciplinas del diseño' },
]
---

<section class:list={['bg-surface-raised overflow-hidden', className]}>
  <div class="container-content section-padding section-gap">
    <div class="grid grid-cols-1 gap-12 xl:grid-cols-2 xl:items-center xl:gap-20">

      <!-- Left: image with overlay stat -->
      <Reveal class="relative">
        <div class="relative">
          <!-- Main image -->
          <div class="overflow-hidden rounded-2xl aspect-4/5">
            <Img
              src={image}
              alt="Equipo GrafiVisión trabajando"
              width={560}
              height={700}
              class="h-full w-full object-cover"
            />
          </div>

          <!-- Floating stat card -->
          <div
            class="absolute -bottom-6 -right-4 xl:-right-8 rounded-2xl border border-surface-border bg-surface-base p-5 shadow-lg"
            aria-hidden="true"
          >
            <div class="flex items-center gap-4">
              <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-brand-red">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.5" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.562.562 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z" />
                </svg>
              </div>
              <div>
                <p class="text-2xl font-bold font-display text-text-primary">12+</p>
                <p class="text-xs text-text-muted">Años de trayectoria</p>
              </div>
            </div>
          </div>

          <!-- Decorative red line -->
          <div class="absolute -top-4 -left-4 h-20 w-1 rounded-full bg-brand-red" aria-hidden="true" />
          <div class="absolute -top-4 -left-4 h-1 w-20 rounded-full bg-brand-red" aria-hidden="true" />
        </div>
      </Reveal>

      <!-- Right: content -->
      <div>
        <Reveal>
          <span class="mb-4 inline-block text-xs font-semibold uppercase tracking-[0.2em] text-brand-red">
            Sobre nosotros
          </span>
          <h2 class="font-display text-3xl font-bold leading-tight text-text-primary xl:text-4xl">
            Creatividad con<br />propósito y pasión
          </h2>
        </Reveal>

        <Reveal delay={1}>
          <Divider variant="accent" class="my-6 w-12" />
          <p class="text-text-secondary leading-relaxed">
            Somos una agencia creativa colombiana especializada en diseño gráfico. Combinamos
            estrategia, creatividad y ejecución técnica para crear piezas que no solo se ven
            bien: comunican, convencen y generan resultados.
          </p>
          <p class="mt-4 text-text-secondary leading-relaxed">
            Desde identidades de marca hasta empaques de exportación, cada proyecto es una
            oportunidad para hacer algo memorable.
          </p>
        </Reveal>

        <!-- Stats 2x2 grid -->
        <Reveal delay={2}>
          <div class="mt-8 grid grid-cols-2 gap-5">
            {highlights.map((h) => (
              <div class="rounded-xl border border-surface-border bg-surface-overlay p-4">
                <p class="font-display text-2xl font-bold text-brand-red">{h.value}</p>
                <p class="mt-1 text-xs text-text-muted">{h.label}</p>
              </div>
            ))}
          </div>
        </Reveal>

        <Reveal delay={3}>
          <Button href="/nosotros" variant="primary" size="md" class="mt-8">
            Conocer más
            <svg width={14} height={14} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 18l6-6-6-6" />
            </svg>
          </Button>
        </Reveal>
      </div>
    </div>
  </div>
</section>
