---
import Img from '@/components/atoms/Img.astro'

interface Props {
  title: string
  description?: string
  image?: string
  imageAlt?: string
  href?: string
  badge?: string
  class?: string
}

const { title, description, image, imageAlt = title, href, badge, class: className } = Astro.props

const Tag = href ? 'a' : 'article'
---

<Tag
  href={href}
  class:list={[
    'group flex flex-col overflow-hidden rounded-xl border border-surface-border bg-surface-raised transition-all duration-300',
    href ? 'hover:border-brand-red/40 hover:-translate-y-1 hover:shadow-lg cursor-pointer' : '',
    className,
  ]}
>
  {image && (
    <div class="relative overflow-hidden aspect-video">
      <Img
        src={image}
        alt={imageAlt}
        width={640}
        height={360}
        class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
      />
      {badge && (
        <span class="absolute top-3 left-3 rounded-pill bg-brand-red px-2.5 py-0.5 text-xs font-semibold text-white">
          {badge}
        </span>
      )}
    </div>
  )}
  <div class="flex flex-1 flex-col gap-3 p-5">
    <h3 class="font-display text-base font-semibold text-text-primary group-hover:text-brand-red transition-colors duration-200">
      {title}
    </h3>
    {description && (
      <p class="text-sm text-text-secondary leading-relaxed line-clamp-3">{description}</p>
    )}
    <slot />
    {href && (
      <div class="mt-auto pt-3">
        <span class="inline-flex items-center gap-1.5 text-sm font-medium text-brand-red">
          Ver más
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="transition-transform duration-200 group-hover:translate-x-1" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 18l6-6-6-6" />
          </svg>
        </span>
      </div>
    )}
  </div>
</Tag>
