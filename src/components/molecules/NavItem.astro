---
interface Props {
  label: string
  href: string
  class?: string
}

const { label, href, class: className } = Astro.props

const currentPath = Astro.url.pathname
const isActive = currentPath === href || (href !== '/' && currentPath.startsWith(href))
---

<a
  href={href}
  class:list={[
    'relative text-sm font-medium leading-none transition-colors duration-200',
    'after:absolute after:bottom-0 after:left-0 after:h-0.5 after:w-0 after:bg-gradient-to-r after:from-brand-red after:to-brand-orange after:transition-all after:duration-300 hover:after:w-full',
    isActive
      ? 'text-brand-red after:w-full'
      : 'text-text-secondary hover:text-brand-red',
    className,
  ]}
  aria-current={isActive ? 'page' : undefined}
>
  {label}
</a>
