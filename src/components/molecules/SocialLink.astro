---
type Platform = 'instagram' | 'linkedin' | 'behance' | 'dribbble' | 'twitter'

interface Props {
  platform: Platform
  href: string
  label?: boolean
  size?: 'sm' | 'md'
  class?: string
}

const { platform, href, label = false, size = 'md', class: className } = Astro.props

const labels: Record<Platform, string> = {
  instagram: 'Instagram',
  linkedin:  'LinkedIn',
  behance:   'Behance',
  dribbble:  'Dribbble',
  twitter:   'X (Twitter)',
}

const iconSize = size === 'sm' ? 16 : 20
---

<a
  href={href}
  target="_blank"
  rel="noopener noreferrer"
  aria-label={`GrafiVisión en ${labels[platform]}`}
  class:list={[
    'inline-flex items-center gap-2 text-text-muted hover:text-brand-red transition-colors duration-200',
    className,
  ]}
>
  {platform === 'instagram' && (
    <svg width={iconSize} height={iconSize} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <rect width="20" height="20" x="2" y="2" rx="5" ry="5"/>
      <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/>
      <line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/>
    </svg>
  )}

  {platform === 'linkedin' && (
    <svg width={iconSize} height={iconSize} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/>
      <rect width="4" height="12" x="2" y="9"/>
      <circle cx="4" cy="4" r="2"/>
    </svg>
  )}

  {platform === 'behance' && (
    <svg width={iconSize} height={iconSize} viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
      <path d="M22 7h-7V5h7v2zm1.726 10c-.442 1.297-2.029 3-5.101 3-3.074 0-5.564-1.729-5.564-5.675 0-3.91 2.325-5.92 5.466-5.92 3.082 0 4.964 1.782 5.375 4.426.078.506.109 1.188.095 2.14H15.97c.13 3.211 3.483 3.312 4.588 2.029h3.168zm-7.686-4h4.965c-.105-1.547-1.136-2.219-2.477-2.219-1.466 0-2.277.768-2.488 2.219zm-9.574 6.988H0V5.021h6.953c5.476.081 5.58 5.444 2.72 6.906 3.461 1.26 3.577 8.061-3.207 8.061zM3 11h3.584c2.508 0 2.906-3-.312-3H3v3zm3.391 3H3v3.016h3.341c3.055 0 2.868-3.016.05-3.016z"/>
    </svg>
  )}

  {platform === 'dribbble' && (
    <svg width={iconSize} height={iconSize} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <circle cx="12" cy="12" r="10"/>
      <path d="M19.13 5.09C15.22 9.14 10 10.44 2.25 10.94"/>
      <path d="M21.75 12.84c-6.62-1.41-12.14 1-16.38 6.32"/>
      <path d="M8.56 2.75c4.37 6 6 9.42 8 17.72"/>
    </svg>
  )}

  {platform === 'twitter' && (
    <svg width={iconSize} height={iconSize} viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
      <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
    </svg>
  )}

  {label && <span class="text-sm">{labels[platform]}</span>}
</a>
