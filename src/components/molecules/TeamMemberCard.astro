---
import Img from '@/components/atoms/Img.astro'
import SocialLink from '@/components/molecules/SocialLink.astro'
import type { TeamMember } from '@/lib/types'

interface Props extends TeamMember {
  class?: string
}

const { name, role, bio, photo, social, class: className } = Astro.props
---

<article class:list={['group overflow-hidden rounded-2xl border border-surface-border bg-surface-raised', className]}>
  <!-- Photo -->
  <div class="relative overflow-hidden aspect-3/4">
    <Img
      src={photo}
      alt={name}
      width={360}
      height={480}
      class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-105"
    />
    <div class="absolute inset-0 bg-linear-to-t from-black/80 to-transparent opacity-0 transition-opacity duration-300 group-hover:opacity-100" />
  </div>

  <!-- Info -->
  <div class="p-5">
    <h3 class="font-display text-base font-bold text-text-primary">{name}</h3>
    <p class="mt-0.5 text-sm font-medium text-brand-red">{role}</p>
    {bio && (
      <p class="mt-3 text-sm text-text-secondary leading-relaxed line-clamp-3">{bio}</p>
    )}
    {social && Object.values(social).some(Boolean) && (
      <div class="mt-4 flex items-center gap-3">
        {social.instagram && <SocialLink platform="instagram" href={social.instagram} size="sm" />}
        {social.linkedin  && <SocialLink platform="linkedin"  href={social.linkedin}  size="sm" />}
        {social.behance   && <SocialLink platform="behance"   href={social.behance}   size="sm" />}
        {social.dribbble  && <SocialLink platform="dribbble"  href={social.dribbble}  size="sm" />}
        {social.twitter   && <SocialLink platform="twitter"   href={social.twitter}   size="sm" />}
      </div>
    )}
  </div>
</article>
