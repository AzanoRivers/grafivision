---
interface Props {
  src?: string
  alt: string
  size?: 'sm' | 'md' | 'lg' | 'xl'
  class?: string
}

const { src, alt, size = 'md', class: className } = Astro.props

const sizes: Record<string, string> = {
  sm: 'h-8 w-8 text-xs',
  md: 'h-10 w-10 text-sm',
  lg: 'h-14 w-14 text-base',
  xl: 'h-20 w-20 text-xl',
}

const initials = alt
  .split(' ')
  .map((w) => w[0])
  .slice(0, 2)
  .join('')
  .toUpperCase()
---

<div
  class:list={[
    'relative inline-flex shrink-0 items-center justify-center overflow-hidden rounded-full bg-surface-overlay',
    sizes[size],
    className,
  ]}
  aria-label={alt}
>
  {src ? (
    <img src={src} alt={alt} class="h-full w-full object-cover" width="80" height="80" loading="lazy" decoding="async" />
  ) : (
    <span class="font-semibold text-text-secondary">{initials}</span>
  )}
</div>
