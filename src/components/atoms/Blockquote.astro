---
interface Props {
  author?: string
  company?: string
  class?: string
}

const { author, company, class: className } = Astro.props
---

<blockquote class:list={['relative pl-6 border-l-2 border-brand-red', className]}>
  <svg
    class="absolute -top-1 -left-1 h-5 w-5 text-brand-red/40"
    viewBox="0 0 24 24"
    fill="currentColor"
    aria-hidden="true"
  >
    <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z" />
  </svg>
  <p class="text-base italic text-text-secondary leading-relaxed">
    <slot />
  </p>
  {(author || company) && (
    <footer class="mt-3 flex items-center gap-2">
      {author && <cite class="text-sm font-semibold not-italic text-text-primary">{author}</cite>}
      {author && company && <span class="text-text-muted">·</span>}
      {company && <span class="text-sm text-text-muted">{company}</span>}
    </footer>
  )}
</blockquote>
