---
interface Props {
  variant?: 'full' | 'mark'
  size?: 'sm' | 'md' | 'lg'
  class?: string
}

const { variant = 'full', size = 'md', class: className } = Astro.props

const markSizes: Record<string, number> = {
  sm: 28,
  md: 36,
  lg: 48,
}

const textSizes: Record<string, string> = {
  sm: 'text-lg',
  md: 'text-xl',
  lg: 'text-2xl',
}

const markSize = markSizes[size]
const textSize = textSizes[size]
---

<a
  href="/"
  class:list={['logo-link inline-flex items-center gap-3 transition-colors duration-300', className]}
  aria-label="GrafiVisión, ir al inicio"
>
  <img
    src="/logo-camaleon.png"
    width={markSize}
    height={markSize}
    alt=""
    aria-hidden="true"
    class="shrink-0 object-contain"
    loading="eager"
  />

  {
    variant === 'full' && (
      <span class:list={['logo-text font-display font-bold tracking-tight', textSize]}>
        GrafiVisión
      </span>
    )
  }
</a>

<style>
  .logo-text {
    color: var(--color-brand-red);
    transition: color 0.25s ease, opacity 0.25s ease;
  }

  .logo-link:hover .logo-text {
    background: linear-gradient(
      90deg,
      #e8222b 0%,
      #ff6b35 22%,
      #ffd700 44%,
      #22c55e 58%,
      #3b82f6 76%,
      #8b5cf6 100%
    );
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }
</style>
