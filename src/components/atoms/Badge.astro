---
interface Props {
  variant?: 'default' | 'red' | 'orange' | 'pink' | 'success' | 'muted'
  size?: 'sm' | 'md'
  class?: string
}

const { variant = 'default', size = 'sm', class: className } = Astro.props

const variants: Record<string, string> = {
  default: 'bg-surface-overlay text-text-secondary border border-surface-border',
  red:     'bg-brand-red/10 text-brand-red border border-brand-red/20',
  orange:  'bg-brand-orange/10 text-brand-orange border border-brand-orange/20',
  pink:    'bg-brand-pink/10 text-brand-pink border border-brand-pink/20',
  success: 'bg-state-success/10 text-state-success border border-state-success/20',
  muted:   'bg-surface-muted/40 text-text-muted border border-surface-border',
}

const sizes: Record<string, string> = {
  sm: 'px-2.5 py-0.5 text-xs',
  md: 'px-3 py-1 text-sm',
}
---

<span class:list={['inline-flex items-center rounded-pill font-medium', variants[variant], sizes[size], className]}>
  <slot />
</span>
