---
import Img from '@/components/atoms/Img.astro'
import PageHero from '@/components/organisms/PageHero.astro'
import SubscribeBar from '@/components/organisms/SubscribeBar.astro'
import Reveal from '@/components/transitions/Reveal.astro'
import PageLayout from '@/layouts/PageLayout.astro'
import { getCollection } from 'astro:content'

const categoryLabels: Record<string, string> = {
  diseno:     'Diseño',
  branding:   'Branding',
  tendencias: 'Tendencias',
  tips:       'Tips',
}

const activeCat = Astro.url.searchParams.get('cat') ?? ''

const allPosts = await getCollection('blog')
const filteredPosts = activeCat
  ? allPosts.filter((p) => p.data.category === activeCat)
  : allPosts
const posts = filteredPosts.sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())

const cats = Object.keys(categoryLabels)
const counts: Record<string, number> = {}
for (const cat of cats) {
  counts[cat] = allPosts.filter((p) => p.data.category === cat).length
}

function formatDate(date: Date): string {
  return date.toLocaleDateString('es-CO', { day: 'numeric', month: 'long', year: 'numeric' })
}
---

<PageLayout
  title="Blog"
  description="Artículos sobre diseño gráfico, branding, packaging y comunicación visual para empresas colombianas que quieren destacar."
  preloadImage="/images/banner/vertical_banner.png"
>

  <PageHero
    badge="Blog"
    title="Ideas, recursos y reflexiones"
    subtitle="Compartimos lo que sabemos sobre diseño gráfico, branding y comunicación visual."
    image="/images/banner/vertical_banner.png"
  />

  <!-- ── Filter + Grid ──────────────────────────────────── -->
  <section class="bg-surface-base">
    <div class="container-content section-padding section-gap">

      <!-- Category tabs -->
      <div class="mb-10 flex flex-wrap items-center gap-2">
        <a
          href="/blog"
          class:list={[
            'rounded-full border px-4 py-1.5 text-sm font-medium transition-colors duration-200',
            !activeCat
              ? 'border-brand-red bg-brand-red text-white'
              : 'border-surface-border text-text-secondary hover:border-brand-red hover:text-brand-red',
          ]}
        >
          Todos <span class="ml-1 opacity-70">({allPosts.length})</span>
        </a>
        {cats.map((cat) => (
          <a
            href={`/blog?cat=${cat}`}
            class:list={[
              'rounded-full border px-4 py-1.5 text-sm font-medium transition-colors duration-200',
              activeCat === cat
                ? 'border-brand-red bg-brand-red text-white'
                : 'border-surface-border text-text-secondary hover:border-brand-red hover:text-brand-red',
            ]}
          >
            {categoryLabels[cat]} <span class="ml-1 opacity-70">({counts[cat]})</span>
          </a>
        ))}
      </div>

      {posts.length === 0 ? (
        <div class="py-20 text-center">
          <p class="text-text-muted">No hay artículos en esta categoría aún.</p>
        </div>
      ) : (
        <div class="grid grid-cols-1 gap-6 xl:grid-cols-3">
          {posts.map((post, i) => (
            <Reveal delay={(i % 3) as 0|1|2}>
              <article class="group flex h-full flex-col overflow-hidden rounded-2xl border border-surface-border bg-surface-raised transition-shadow duration-300 hover:shadow-md">

                <!-- Thumbnail -->
                <a href={`/blog/${post.id}`} class="block overflow-hidden aspect-video shrink-0" aria-hidden="true" tabindex="-1">
                  <Img
                    src={post.data.thumbnail}
                    alt={post.data.title}
                    width={640}
                    height={360}
                    class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-105"
                    loading={i < 3 ? 'eager' : 'lazy'}
                    decoding={i < 3 ? 'sync' : 'async'}
                  />
                </a>

                <!-- Content -->
                <div class="flex flex-1 flex-col p-5">
                  <div class="mb-3 flex items-center gap-2">
                    <span class="rounded-full bg-brand-red/10 px-2.5 py-0.5 text-xs font-semibold text-brand-red">
                      {categoryLabels[post.data.category]}
                    </span>
                    {post.data.featured && (
                      <span class="rounded-full bg-surface-overlay px-2.5 py-0.5 text-xs font-medium text-text-muted">
                        Destacado
                      </span>
                    )}
                  </div>

                  <a href={`/blog/${post.id}`} class="group/link flex-1">
                    <h2 class="font-display text-base font-bold leading-snug text-text-primary transition-colors group-hover/link:text-brand-red">
                      {post.data.title}
                    </h2>
                    <p class="mt-2 text-sm text-text-secondary leading-relaxed line-clamp-3">
                      {post.data.description}
                    </p>
                  </a>

                  <div class="mt-4 flex items-center justify-between">
                    <span class="text-xs text-text-muted">{formatDate(post.data.pubDate)}</span>
                    <a
                      href={`/blog/${post.id}`}
                      class="flex items-center gap-1.5 text-xs font-semibold text-brand-red transition-all hover:gap-2.5"
                    >
                      Leer
                      <svg width={12} height={12} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                      </svg>
                    </a>
                  </div>
                </div>

              </article>
            </Reveal>
          ))}
        </div>
      )}

    </div>
  </section>

  <SubscribeBar />

</PageLayout>
