---
import { getCollection, render } from 'astro:content'
import Button from '@/components/atoms/Button.astro'
import Divider from '@/components/atoms/Divider.astro'
import Img from '@/components/atoms/Img.astro'
import Reveal from '@/components/transitions/Reveal.astro'
import PageLayout from '@/layouts/PageLayout.astro'
import CtaBanner from '@/components/organisms/CtaBanner.astro'
import SubscribeBar from '@/components/organisms/SubscribeBar.astro'

const { slug } = Astro.params

const allPosts = await getCollection('blog')
const entry = allPosts.find((p) => p.id === slug)

if (!entry) {
  return Astro.redirect('/blog')
}

const { Content } = await render(entry)

const categoryLabels: Record<string, string> = {
  diseno:     'Diseño',
  branding:   'Branding',
  tendencias: 'Tendencias',
  tips:       'Tips',
}

function formatDate(date: Date): string {
  return date.toLocaleDateString('es-CO', { day: 'numeric', month: 'long', year: 'numeric' })
}

// Estimate read time
const wordCount = entry.body?.split(/\s+/).length ?? 0
const readTime = Math.max(1, Math.ceil(wordCount / 200))

// Related posts: same category, exclude current, max 3
const related = allPosts
  .filter((p) => p.data.category === entry.data.category && p.id !== entry.id)
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
  .slice(0, 3)
---

<PageLayout
  title={entry.data.title}
  description={entry.data.description}
  ogImage={entry.data.thumbnail}
  ogImageAlt={`${entry.data.title} · Blog de GrafiVisión`}
>

  <!-- ── Post header ────────────────────────────────────── -->
  <section class="bg-surface-raised border-b border-surface-border">
    <div class="container-content section-padding py-14">

      <!-- Breadcrumb -->
      <nav class="mb-6 flex items-center gap-2 text-xs text-text-muted" aria-label="Ruta de navegación">
        <a href="/" class="hover:text-brand-red transition-colors">Inicio</a>
        <span aria-hidden="true">/</span>
        <a href="/blog" class="hover:text-brand-red transition-colors">Blog</a>
        <span aria-hidden="true">/</span>
        <span class="text-text-secondary line-clamp-1">{entry.data.title}</span>
      </nav>

      <div class="mx-auto max-w-3xl">
        <!-- Category + date -->
        <div class="mb-4 flex flex-wrap items-center gap-3">
          <a
            href={`/blog?cat=${entry.data.category}`}
            class="rounded-full bg-brand-red/10 px-3 py-1 text-xs font-semibold text-brand-red transition-colors hover:bg-brand-red hover:text-white"
          >
            {categoryLabels[entry.data.category]}
          </a>
          <span class="text-xs text-text-muted">{formatDate(entry.data.pubDate)}</span>
          <span class="text-xs text-text-muted">{readTime} min de lectura</span>
        </div>

        <!-- Title -->
        <h1 class="font-display text-3xl font-bold leading-tight text-text-primary xl:text-4xl">
          {entry.data.title}
        </h1>

        <Divider variant="accent" class="my-6 w-12" />

        <!-- Description -->
        <p class="text-lg text-text-secondary leading-relaxed">
          {entry.data.description}
        </p>

        <!-- Author -->
        <div class="mt-6 flex items-center gap-3">
          <div class="flex h-9 w-9 shrink-0 items-center justify-center rounded-full bg-brand-red/10">
            <svg width={16} height={16} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-brand-red" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z" />
            </svg>
          </div>
          <div>
            <p class="text-sm font-semibold text-text-primary">{entry.data.author}</p>
            <p class="text-xs text-text-muted">Equipo GrafiVisión</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Thumbnail ──────────────────────────────────────── -->
  <div class="bg-surface-raised">
    <div class="container-content section-padding">
      <div class="mx-auto max-w-3xl overflow-hidden rounded-2xl">
        <Img
          src={entry.data.thumbnail}
          alt={entry.data.title}
          width={900}
          height={506}
          class="h-auto w-full object-cover"
          loading="eager"
          fetchpriority="high"
        />
      </div>
    </div>
  </div>

  <!-- ── Content + sidebar ──────────────────────────────── -->
  <section class="bg-surface-base">
    <div class="container-content section-padding py-12">
      <div class="mx-auto grid max-w-5xl grid-cols-1 gap-12 xl:grid-cols-[1fr_280px]">

        <!-- Article body -->
        <article class="prose-blog">
          <Content />
        </article>

        <!-- Sidebar -->
        <aside class="space-y-6">

          <!-- Tags -->
          {entry.data.tags.length > 0 && (
            <div class="rounded-2xl border border-surface-border bg-surface-raised p-5">
              <h3 class="mb-3 font-display text-sm font-bold text-text-primary">Etiquetas</h3>
              <div class="flex flex-wrap gap-2">
                {entry.data.tags.map((tag) => (
                  <span class="rounded-full bg-surface-overlay px-2.5 py-1 text-xs text-text-secondary">
                    {tag}
                  </span>
                ))}
              </div>
            </div>
          )}

          <!-- Category -->
          <div class="rounded-2xl border border-surface-border bg-surface-raised p-5">
            <h3 class="mb-3 font-display text-sm font-bold text-text-primary">Categoría</h3>
            <a
              href={`/blog?cat=${entry.data.category}`}
              class="inline-flex items-center gap-1.5 text-sm font-medium text-brand-red hover:text-brand-red-dark transition-colors"
            >
              {categoryLabels[entry.data.category]}
              <svg width={14} height={14} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </a>
          </div>

          <!-- CTA card -->
          <div class="rounded-2xl bg-brand-red p-5 text-white">
            <h3 class="font-display text-base font-bold leading-tight">
              ¿Tienes un proyecto?
            </h3>
            <p class="mt-2 text-sm leading-relaxed text-white/80">
              Hablemos de tu marca. Respondemos en menos de 24 horas.
            </p>
            <Button href="/contacto" variant="outline" size="sm" class="mt-4 border-white text-white hover:bg-white hover:text-brand-red">
              Contáctanos
            </Button>
          </div>

        </aside>
      </div>
    </div>
  </section>

  <!-- ── Related posts ─────────────────────────────────── -->
  {related.length > 0 && (
    <section class="border-t border-surface-border bg-surface-raised">
      <div class="container-content section-padding py-12">

        <Reveal class="mb-8">
          <h2 class="font-display text-2xl font-bold text-text-primary">
            Artículos relacionados
          </h2>
        </Reveal>

        <div class="grid grid-cols-1 gap-5 xl:grid-cols-3">
          {related.map((post, i) => (
            <Reveal delay={(i % 3) as 0|1|2}>
              <article class="group overflow-hidden rounded-xl border border-surface-border bg-surface-raised transition-shadow hover:shadow-md">
                <a href={`/blog/${post.id}`} class="block overflow-hidden aspect-video" aria-hidden="true" tabindex="-1">
                  <Img
                    src={post.data.thumbnail}
                    alt={post.data.title}
                    width={400}
                    height={225}
                    class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
                  />
                </a>
                <div class="p-4">
                  <span class="text-xs font-semibold text-brand-red">{categoryLabels[post.data.category]}</span>
                  <a href={`/blog/${post.id}`}>
                    <h3 class="mt-1 font-display text-sm font-bold text-text-primary leading-snug transition-colors group-hover:text-brand-red">
                      {post.data.title}
                    </h3>
                  </a>
                  <p class="mt-1.5 text-xs text-text-muted">{formatDate(post.data.pubDate)}</p>
                </div>
              </article>
            </Reveal>
          ))}
        </div>

        <div class="mt-8 text-center">
          <Button href="/blog" variant="outline">Ver todos los artículos</Button>
        </div>

      </div>
    </section>
  )}

  <CtaBanner
    title="Trabajemos juntos"
    subtitle="Cuéntanos tu proyecto. Respondemos en menos de 24 horas con una propuesta inicial."
    primaryLabel="Enviar mensaje"
    primaryHref="/contacto"
    secondaryLabel="Ver portafolio"
    secondaryHref="/portafolio"
  />

  <SubscribeBar />

</PageLayout>
