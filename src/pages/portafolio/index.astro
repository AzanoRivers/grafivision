---
import PageLayout from '@/layouts/PageLayout.astro'
import PageHero from '@/components/organisms/PageHero.astro'
import { PortfolioFilter } from '@/components/islands/PortfolioFilter'
import CtaBanner from '@/components/organisms/CtaBanner.astro'
import SubscribeBar from '@/components/organisms/SubscribeBar.astro'
import { portfolioItems } from '@/lib/data/portfolio'
---

<PageLayout
  title="Portafolio"
  description="Portafolio de trabajos en impresión offset, digital, gran formato, material POP y empaques. Producción gráfica de alta calidad en Bogotá."
  preloadImage="/images/brand/GF-2.webp"
>
  <PageHero
    badge="Nuestro trabajo"
    title="Portafolio de proyectos"
    subtitle="Más de 350 proyectos completados. Una selección de trabajos en offset, digital, gran formato, material POP y empaques."
    image="/images/brand/GF-2.webp"
  />

  <section class="bg-surface-base">
    <div class="container-content section-padding section-gap">
      <PortfolioFilter client:load items={portfolioItems} />
    </div>
  </section>

  <CtaBanner
    title="¿Tu proyecto podría estar aquí?"
    subtitle="Cuéntanos qué necesitas. Analizamos tu caso sin costo y te enviamos una propuesta en 24 horas."
    primaryLabel="Empezar proyecto"
    primaryHref="/contacto"
    secondaryLabel="Sobre nosotros"
    secondaryHref="/nosotros"
  />

  <SubscribeBar />
</PageLayout>
