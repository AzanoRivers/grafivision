---
import Divider from "@/components/atoms/Divider.astro";
import CtaBanner from "@/components/organisms/CtaBanner.astro";
import PageHero from "@/components/organisms/PageHero.astro";
import Reveal from "@/components/transitions/Reveal.astro";
import PageLayout from "@/layouts/PageLayout.astro";

const certificaciones = [
  {
    label: "Auditoría SMETA",
    desc: "Sedex Members Ethical Trade Audit. Verificación de prácticas éticas en comercio, condiciones laborales y medio ambiente.",
    icon: "M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z",
    status: "Certificado",
  },
  {
    label: "ISO 9001",
    desc: "Norma internacional de gestión de calidad. Garantiza procesos controlados y mejora continua en todos los niveles de la organización.",
    icon: "M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z",
    status: "En proceso",
  },
  {
    label: "FSC",
    desc: "Forest Stewardship Council. Certificación que garantiza el uso de materiales provenientes de bosques gestionados de forma responsable.",
    icon: "M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z",
    status: "En proceso",
  },
];

const politica = [
  "Mejoramiento continuo de los procesos productivos",
  "Satisfacción de los clientes en cada entrega",
  "Fidelización y consecución de nuevos clientes",
  "Rentabilidad sostenible del negocio",
  "Personal y proveedores calificados y comprometidos",
];
---

<PageLayout
  title="Sostenibilidad"
  description="GrafiVisión Editores S.A.S. comprometida con prácticas responsables. Certificaciones SMETA, ISO 9001 y FSC para producción gráfica sostenible en Bogotá."
  preloadImage="/images/banner/vertical_banner.png"
>
  <PageHero
    badge="Sostenibilidad"
    title="Compromiso con el futuro"
    subtitle="Prácticas responsables con el medio ambiente y las personas en cada proceso productivo."
    image="/images/banner/vertical_banner.png"
  />

  <!-- Compromiso -->
  <section class="bg-surface-base">
    <div class="container-content section-padding section-gap">
      <div
        class="grid grid-cols-1 gap-12 xl:grid-cols-2 xl:items-center xl:gap-20"
      >
        <Reveal>
          <span
            class="mb-4 inline-block text-xs font-semibold uppercase tracking-[0.2em] text-brand-red"
          >
            Nuestro compromiso
          </span>
          <h2
            class="font-display text-3xl font-bold text-text-primary xl:text-4xl"
          >
            Producción gráfica responsable
          </h2>
          <Divider variant="accent" class="my-6 w-12" />
          <p class="text-text-secondary leading-relaxed">
            En GrafiVisión Editores estamos comprometidos con prácticas
            responsables en todos nuestros procesos productivos. Creemos que la
            excelencia gráfica y el cuidado del medio ambiente no son conceptos
            opuestos, sino complementarios.
          </p>
          <p class="mt-4 text-text-secondary leading-relaxed">
            Por eso avanzamos hacia la certificación en estándares
            internacionales que garantizan ética, calidad y sostenibilidad en
            cada etapa de producción, desde los insumos hasta la entrega final.
          </p>
        </Reveal>

        <!-- Política de calidad -->
        <Reveal delay={1}>
          <div
            class="rounded-2xl border border-surface-border bg-surface-raised p-8"
          >
            <h3 class="mb-6 font-display text-lg font-bold text-text-primary">
              Política de calidad
            </h3>
            <ul class="space-y-4">
              {
                politica.map((item) => (
                  <li class="flex items-start gap-3 text-sm text-text-secondary">
                    <span
                      class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full bg-brand-red"
                      aria-hidden="true"
                    />
                    {item}
                  </li>
                ))
              }
            </ul>
          </div>
        </Reveal>
      </div>
    </div>
  </section>

  <!-- Certificaciones -->
  <section class="bg-surface-raised">
    <div class="container-content section-padding section-gap">
      <Reveal class="mb-12 text-center">
        <span
          class="mb-3 inline-block text-xs font-semibold uppercase tracking-[0.2em] text-brand-red"
        >
          Certificaciones
        </span>
        <h2
          class="font-display text-3xl font-bold text-text-primary xl:text-4xl"
        >
          Estándares internacionales
        </h2>
        <p class="mx-auto mt-4 max-w-xl text-text-secondary">
          Avanzamos constantemente hacia los más altos estándares de calidad,
          ética y sostenibilidad reconocidos a nivel mundial.
        </p>
      </Reveal>

      <div class="grid grid-cols-1 gap-6 md:grid-cols-3">
        {
          certificaciones.map((cert, i) => (
            <Reveal delay={(i + 1) as 1 | 2 | 3}>
              <article class="group flex flex-col gap-5 rounded-2xl border border-surface-border bg-surface-base p-8 transition-colors duration-300 hover:border-brand-red/40">
                <div class="flex items-start justify-between">
                  <div class="flex h-14 w-14 items-center justify-center rounded-2xl bg-brand-red/10 transition-colors duration-300 group-hover:bg-brand-red">
                    <svg
                      width="26"
                      height="26"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="1.5"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      class="text-brand-red transition-colors duration-300 group-hover:text-white"
                      aria-hidden="true"
                    >
                      <path d={cert.icon} />
                    </svg>
                  </div>
                  <span
                    class={[
                      "rounded-full px-3 py-1 text-xs font-semibold",
                      cert.status === "Certificado"
                        ? "bg-green-100 text-green-700"
                        : "bg-amber-100 text-amber-700",
                    ].join(" ")}
                  >
                    {cert.status}
                  </span>
                </div>

                <div>
                  <h3 class="font-display text-xl font-bold text-text-primary">
                    {cert.label}
                  </h3>
                  <p class="mt-3 text-sm text-text-secondary leading-relaxed">
                    {cert.desc}
                  </p>
                </div>
              </article>
            </Reveal>
          ))
        }
      </div>
    </div>
  </section>

  <CtaBanner
    title="Producción responsable para tu marca"
    subtitle="Trabajamos con estándares éticos y sostenibles en cada proyecto. Contáctanos y conócenos."
    primaryLabel="Contáctanos"
    primaryHref="/contacto"
    secondaryLabel="Quiénes somos"
    secondaryHref="/nosotros"
  />
</PageLayout>
