---
import CtaBanner from "@/components/organisms/CtaBanner.astro";
import PageHero from "@/components/organisms/PageHero.astro";
import ProductsSection from "@/components/organisms/ProductsSection.astro";
import ServicesGrid from "@/components/organisms/ServicesGrid.astro";
import StatsSection from "@/components/organisms/StatsSection.astro";
import Reveal from "@/components/transitions/Reveal.astro";
import PageLayout from "@/layouts/PageLayout.astro";

const diferenciales = [
  {
    icon: "M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z",
    title: "Experiencia",
    desc: "Más de 33 años de trayectoria en el sector gráfico nos respaldan.",
  },
  {
    icon: "M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z",
    title: "Calidad",
    desc: "Procesos controlados que garantizan resultados consistentes en cada producción.",
  },
  {
    icon: "M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z",
    title: "Tecnología",
    desc: "Equipos de impresión de última generación para resultados precisos y de alta calidad.",
  },
  {
    icon: "M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z",
    title: "Sostenibilidad",
    desc: "Procesos responsables con el medio ambiente. Certificados SMETA, ISO 9001 y FSC.",
  },
];
---

<PageLayout
  title="Servicios"
  description="Impresión offset, digital, gran formato, material POP y empaques. Soluciones integrales en artes gráficas con más de 33 años de experiencia en Bogotá."
  preloadImage="/images/banner/vertical_banner.png"
>
  <PageHero
    badge="Servicios"
    title="Soluciones integrales en artes gráficas"
    subtitle="Más de 33 años de experiencia en impresión y producción publicitaria en Bogotá."
    image="/images/banner/vertical_banner.png"
  />

  <ServicesGrid
    title="Lo que producimos"
    subtitle="Desde tirajes cortos hasta grandes volúmenes, con tecnología de punta y acabados profesionales."
  />

  <!-- Diferenciales -->
  <section class="bg-surface-raised">
    <div class="container-content section-padding section-gap">
      <Reveal class="mb-12 text-center">
        <span
          class="mb-3 inline-block text-xs font-semibold uppercase tracking-[0.2em] text-brand-red"
        >
          Por qué elegirnos
        </span>
        <h2
          class="font-display text-3xl font-bold text-text-primary xl:text-4xl"
        >
          Nuestros diferenciales
        </h2>
      </Reveal>

      <div class="grid grid-cols-1 gap-6 md:grid-cols-2 xl:grid-cols-4">
        {
          diferenciales.map((d, i) => (
            <Reveal delay={((i % 4) + 1) as 1 | 2 | 3 | 4}>
              <article class="group flex flex-col gap-4 rounded-2xl border border-surface-border bg-surface-overlay p-6 transition-colors duration-300 hover:border-brand-red/40">
                <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-brand-red/10 transition-colors duration-300 group-hover:bg-brand-red">
                  <svg
                    width="22"
                    height="22"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    class="text-brand-red transition-colors duration-300 group-hover:text-white"
                    aria-hidden="true"
                  >
                    <path d={d.icon} />
                  </svg>
                </div>
                <div>
                  <h3 class="font-display text-base font-bold text-text-primary">
                    {d.title}
                  </h3>
                  <p class="mt-2 text-sm text-text-secondary leading-relaxed">
                    {d.desc}
                  </p>
                </div>
              </article>
            </Reveal>
          ))
        }
      </div>
    </div>
  </section>

  <ProductsSection />

  <StatsSection />

  <CtaBanner
    title="¿Necesitas una cotización?"
    subtitle="Cuéntanos tu proyecto. Respondemos en 24 horas con una propuesta detallada sin costo."
    primaryLabel="Solicitar cotización"
    primaryHref="/contacto"
    secondaryLabel="Quiénes somos"
    secondaryHref="/nosotros"
  />
</PageLayout>
