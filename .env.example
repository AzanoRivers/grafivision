# ─── Site ──────────────────────────────────────────────────────
# Production URL (used for OG meta, canonical URLs, sitemap)
PUBLIC_SITE_URL=https://grafivision.com.co

# ─── Contact Form ───────────────────────────────────────────────
# Resend API key — get it at https://resend.com
# Run: pnpm add resend
RESEND_API_KEY=re_xxxxxxxxxxxxx

# Destination email for contact form submissions
CONTACT_EMAIL_TO=info@grafivision.com.co

# ─── Maps ───────────────────────────────────────────────────────
# Google Maps embed URL (no API key required)
# 1. Go to https://maps.google.com
# 2. Search your location → Share → Embed a map → copy the src URL
PUBLIC_MAPS_EMBED_URL=https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3976.5990362445!2d-74.0712866!3d4.6653585!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x8e3f9a55de3c7651%3A0x135a4a547ad6c965!2sGrafiVisi%C3%B3n%20Editores%20S.A.S.!5e0!3m2!1ses!2sco!4v1777052733592!5m2!1ses!2sco

# ─── Image CDN (optional) ───────────────────────────────────────
# Cloudflare Images CDN for production image delivery
# Format: https://imagedelivery.net/{ACCOUNT_HASH}/{IMAGE_ID}/{variant}
# Variants: public | thumbnail | portfolio | hero
PUBLIC_CF_IMAGES_ACCOUNT=your-cloudflare-account-hash
